PORT=3000
NODE_ENV=production

# Gmail (App Password, no la contraseña normal)
GMAIL_USER=tucorreo@gmail.com
GMAIL_PASS=xxxxxxxxxxxxxxxx

# Email donde llegan las notificaciones de nuevas reservas
NOTIFICATION_EMAIL=tucorreo@gmail.com

# URL pública de la aplicación (para enlaces en correos de invitación)
APP_URL=http://localhost:3000

# Kikoto API (API externa de rutas y horarios)
KIKOTO_API_BASE=https://api.b2b.kikoto.com/v1
KIKOTO_API_TOKEN=

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/alsa_db
DB_SSL=false
